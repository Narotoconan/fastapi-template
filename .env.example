# 通用环境变量参考。配置类读取的是进程环境变量，不会自动加载本文件。
# 按部署环境将需要覆盖的变量注入进程；未提供的可选项使用 config/ 中的代码默认值。

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
# 必填：请设置为实际环境的数据库密码
DB_PASSWORD=
DB_DATABASE=postgres

# 连接池参数按单个应用进程计算；单进程峰值连接数约为 POOL_SIZE + MAX_OVERFLOW。
# 多进程部署时，应再乘以进程数，并确保不超过 PostgreSQL 的连接上限。
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10

# 连接存活超过该秒数后会在下次取用时重建，用于规避代理、NAT 等关闭长期空闲连接；-1 表示禁用。
DB_POOL_RECYCLE=300

# 连接池耗尽时等待可用连接的最长秒数；超时后当前数据库操作会失败。
DB_POOL_TIMEOUT=30

# asyncpg 单条数据库命令的默认执行超时（秒），不等同于建立连接的超时。
DB_COMMAND_TIMEOUT=60
# 建立 PostgreSQL 连接的最长等待时间（秒）。
DB_CONNECT_TIMEOUT=30

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
# Redis 逻辑数据库编号；使用 Redis Cluster 时通常只能使用 0。
REDIS_DB=0
# 未启用 Redis 认证时保持为空；启用认证时填写实际密码。
REDIS_PASSWORD=

# Redis 连接池上限按单个应用进程计算；多进程部署时总连接数会相应放大。
REDIS_MAX_CONNECTIONS=10
# 建立 Redis 连接的超时（秒），当前仅用于 socket_connect_timeout。
REDIS_TIMEOUT=5
# 所有缓存键和限流键的命名空间。修改后旧前缀下的数据不会再被命中，应按缓存迁移处理。
REDIS_PREFIX=template

# 日志（Loguru）
# 数值级别：10=DEBUG、20=INFO、30=WARNING、40=ERROR。
LOG_LEVEL=20
# 日志文件保留周期，使用 Loguru 时间表达式，例如 "14 days"。
LOG_RETENTION="14 days"
# 日志文件轮转条件，"00:00" 表示每天本地时间零点轮转。
LOG_ROTATION_TIME=00:00

# CORS / GZip
# 列表类型必须使用 JSON 字符串，不能写成逗号分隔文本。
CORS_ALLOW_ORIGINS="[\"*\"]"
# 开启凭据后必须把允许来源改为明确域名，不能继续使用 ["*"]。
CORS_ALLOW_CREDENTIALS=false
CORS_ALLOW_METHODS="[\"*\"]"
CORS_ALLOW_HEADERS="[\"*\"]"
# 仅压缩响应体不小于该值的响应，单位为字节；过小会增加小响应的 CPU 开销。
GZIP_MINIMUM_SIZE=1000

# JWT
# 必填且至少 32 个字符；不同环境应使用不同强随机值，轮换后已签发 Token 会立即失效。
JWT_SECRET_KEY=
# Token 的签发端和校验端必须使用同一算法，通常无需修改。
JWT_ALGORITHM=HS256
# Access Token 有效期，单位为小时。
JWT_ACCESS_TOKEN_EXPIRE_HOUR=24
# 公开路径采用前缀匹配；配置过宽（如 "/api"）会使整段接口绕过 JWT 鉴权。
# 列表必须使用 JSON 字符串格式。
JWT_PUBLIC_PATHS="[\"/docs\",\"/redoc\",\"/openapi.json\",\"/favicon.ico\",\"/health\",\"/api/auth/login\",\"/api/auth/register\"]"

# 接口速率限制
# 只影响显式使用 @rate_limit(...) 的接口；关闭时这些接口不会访问限流存储。
RATE_LIMIT_ENABLED=false
# 装饰器未单独传额度时使用，格式示例：100/minute、10/second、1000/hour。
RATE_LIMIT_DEFAULT=100/minute
