# Docker 部署环境变量示例。
# 启动命令通过 --env-file 读取 Compose 插值，服务级 env_file 将已启用项注入 API 容器。
# 除下列必填项外，其余变量仅在需要覆盖 config/ 默认值时取消注释。
# 宿主机 Shell 中的同名变量优先级高于 --env-file；部署前应清理无意保留的同名变量。
# 密码或密钥包含 $、${...}、空格、# 等字符时使用单引号包裹，避免被 Compose 插值或截断。

# Compose（必填，仅控制宿主机发布端口；容器内部固定监听 8000）
API_PORT=8000

# PostgreSQL（必填）
# 地址必须从 API 容器内可达；外部数据库不能填写 localhost，可使用 host.docker.internal 或内网地址。
DB_HOST=
# 至少 6 个字符，不要提交真实密码；包含特殊字符时写成 DB_PASSWORD='实际值'。
DB_PASSWORD=

# Redis（必填）
# 地址必须从 API 容器内可达；外部 Redis 不能填写 localhost。
REDIS_HOST=

# JWT（必填，至少 32 个字符；不同环境使用不同强随机值，轮换后现有 Token 会失效）
# 包含特殊字符时写成 JWT_SECRET_KEY='实际值'。
JWT_SECRET_KEY=

# 以下均为可选覆盖项；保持注释时使用 config/ 中的代码默认值。

# PostgreSQL
# DB_PORT=5432
# DB_USER=postgres
# DB_DATABASE=postgres
# 连接池参数按单个 API 进程计算；单进程峰值约为 POOL_SIZE + MAX_OVERFLOW，多进程时还需乘以进程数。
# DB_POOL_SIZE=5
# DB_MAX_OVERFLOW=10
# 连接存活超过该秒数后在下次取用时重建，用于规避代理、NAT 关闭长期空闲连接；-1 表示禁用。
# DB_POOL_RECYCLE=300
# 连接池耗尽时等待可用连接的最长秒数。
# DB_POOL_TIMEOUT=30
# asyncpg 单条命令的默认执行超时（秒），与建立连接超时是两个阶段。
# 默认 60 秒，须小于镜像中的 Uvicorn 优雅关闭 70 秒和 Compose 强制停止 90 秒。
# DB_COMMAND_TIMEOUT=60
# 建立 PostgreSQL 连接的最长等待时间（秒）。
# DB_CONNECT_TIMEOUT=30

# Redis（开启认证时取消 REDIS_PASSWORD 注释并填写密码，特殊字符值同样使用单引号）
# REDIS_PORT=6379
# Redis 逻辑数据库编号；使用 Redis Cluster 时通常只能使用 0。
# REDIS_DB=0
# REDIS_PASSWORD=
# 连接池上限按单个 API 进程计算，多进程部署时总连接数会相应放大。
# REDIS_MAX_CONNECTIONS=10
# 建立 Redis 连接的超时（秒）。
# REDIS_TIMEOUT=5
# Redis 命令执行的最长等待时间（秒），用于避免网络半断开时请求长期阻塞。
# REDIS_COMMAND_TIMEOUT=5
# 缓存键和限流键的命名空间；修改后旧前缀数据不会再被命中，应按缓存迁移处理。
# REDIS_PREFIX=template

# 日志
# 数值级别：10=DEBUG、20=INFO、30=WARNING、40=ERROR。
# LOG_LEVEL=20
# Loguru 日志文件保留周期，例如 "14 days"。
# LOG_RETENTION="14 days"
# Loguru 轮转条件，"00:00" 表示每天本地时间零点轮转。
# LOG_ROTATION_TIME=00:00

# CORS / GZip（列表使用 JSON 字符串格式）
# CORS_ALLOW_ORIGINS="[\"*\"]"
# 开启凭据后必须把允许来源改为明确域名，不能继续使用 ["*"]。
# CORS_ALLOW_CREDENTIALS=false
# CORS_ALLOW_METHODS="[\"*\"]"
# CORS_ALLOW_HEADERS="[\"*\"]"
# 触发 GZip 压缩的最小响应体字节数，过小会增加小响应的 CPU 开销。
# GZIP_MINIMUM_SIZE=1000

# JWT（列表使用 JSON 字符串格式）
# 签发端和校验端必须使用同一算法，通常无需修改。
# JWT_ALGORITHM=HS256
# Access Token 有效期，单位为小时。
# JWT_ACCESS_TOKEN_EXPIRE_HOUR=24
# 公开路径采用精确匹配或路径段子路径匹配；配置过宽（如 "/api"）会使整段接口绕过 JWT 鉴权。
# JWT_PUBLIC_PATHS="[\"/docs\",\"/redoc\",\"/openapi.json\",\"/favicon.ico\",\"/health\",\"/api/auth/login\",\"/api/auth/register\"]"

# 限流
# 只影响显式使用 @rate_limit(...) 的接口；关闭时这些接口不会访问限流存储。
# RATE_LIMIT_ENABLED=false
# 装饰器未单独传额度时使用，格式示例：100/minute、10/second、1000/hour。
# RATE_LIMIT_DEFAULT=100/minute
# 限流 Redis 在运行期不可用时是否放行请求；高安全接口可设为 false 并配合网关限流。
# RATE_LIMIT_FAIL_OPEN=true
# 限流使用独立的小连接池；以下上限和超时均按单个 API 进程计算。
# RATE_LIMIT_REDIS_MAX_CONNECTIONS=5
# RATE_LIMIT_REDIS_POOL_TIMEOUT=0.2
# RATE_LIMIT_REDIS_CONNECT_TIMEOUT=1
# RATE_LIMIT_REDIS_COMMAND_TIMEOUT=0.5
