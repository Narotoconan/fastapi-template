# API
API_PORT=8000

# PostgreSQL
DB_HOST=
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=
DB_DATABASE=postgres
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_RECYCLE=300
DB_POOL_TIMEOUT=30
DB_COMMAND_TIMEOUT=60
DB_CONNECT_TIMEOUT=30

# Redis
REDIS_HOST=
REDIS_PORT=6379
REDIS_DB=0
# 外部 Redis 未开启认证时保持为空
REDIS_PASSWORD=
REDIS_MAX_CONNECTIONS=10
REDIS_TIMEOUT=5
REDIS_PREFIX=fastapi_template

# JWT（必填，至少 32 个字符）
JWT_SECRET_KEY=

# 限流
RATE_LIMIT_ENABLED=false
RATE_LIMIT_DEFAULT=100/minute
